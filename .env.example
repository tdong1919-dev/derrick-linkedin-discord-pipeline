# ─── Autom8 Agent Team — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your own values.
# Never commit .env to git.

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
GOOGLE_SHEETS_ID=

# Service account JSON (single line) — get from Google Cloud Console:
# 1. console.cloud.google.com → IAM & Admin → Service Accounts → Create
# 2. Add role: Editor
# 3. Keys → Add Key → JSON → download
# 4. Share your Google Sheet with the service account email (Editor access)
# 5. Paste the entire JSON on one line below
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Discord ───────────────────────────────────────────────────────────────────
# Webhook URL for your lead-alerts channel:
# Discord → Server → Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Webhook Server ────────────────────────────────────────────────────────────
# Secret header value for n8n → webhook server authentication (make it long)
WEBHOOK_SECRET=your-secret-here
WEBHOOK_PORT=3000

# ── Timara Blog Agent ─────────────────────────────────────────────────────────
# GitHub personal access token with repo write access:
# github.com → Settings → Developer settings → Personal access tokens → Fine-grained
# Permissions needed: Contents (read & write) for each site repo
GITHUB_TOKEN=github_pat_...

# Path to your Google service account key JSON file (for Docs access)
# Same service account as above — also grant it Viewer on the Google Doc
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# ── barebrandingsystems.com GitHub repo (Netlify) ─────────────────────────────
BARE_GITHUB_OWNER=your-github-username
BARE_GITHUB_REPO=barebrandingsystems-site
BARE_GITHUB_BRANCH=main
BARE_POSTS_DIR=content/blog

# ── autom8ig.io GitHub repo (Vercel) ──────────────────────────────────────────
AUTOM8_GITHUB_OWNER=your-github-username
AUTOM8_GITHUB_REPO=autom8ig-site
AUTOM8_GITHUB_BRANCH=main
AUTOM8_POSTS_DIR=content/blog

# ── Links ─────────────────────────────────────────────────────────────────────
# Your Calendly booking link (used in call request drafts)
CALENDLY_URL=https://calendly.com/your-name/30min

# Your product URL (included in high-intent reply drafts)
AUTOM8_URL=https://autom8ig.io
