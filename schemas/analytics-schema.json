{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autom8 Analytics Schema",
  "description": "Schema covering the Analytics tab and the Signups tab in the Autom8 Google Sheets CRM.",
  "type": "object",

  "analytics_tab": {
    "description": "Weekly performance summaries generated by the Sales Analyzer Agent.",
    "google_sheet_tab": "Analytics",
    "column_order": [
      "report_id", "report_date", "week_start", "week_end",
      "leads_added", "messages_sent", "replies_received",
      "reply_rate_pct", "positive_replies", "positive_reply_rate_pct",
      "calls_booked", "call_booking_rate_pct",
      "signups", "signup_rate_pct",
      "top_lead_type", "top_channel", "top_angle",
      "top_objection_1", "top_objection_2", "top_objection_3",
      "recommendation_1", "recommendation_2", "recommendation_3",
      "pipeline_outreach_sent", "pipeline_follow_up_active",
      "pipeline_call_requested", "pipeline_demo_requested",
      "pipeline_pricing_asked", "pipeline_signup_ready",
      "pipeline_closed", "notes"
    ],
    "properties": {
      "report_id": {
        "type": "string",
        "description": "Unique report ID. Format: REPORT-001"
      },
      "report_date": {
        "type": "string",
        "format": "date"
      },
      "week_start": {
        "type": "string",
        "format": "date"
      },
      "week_end": {
        "type": "string",
        "format": "date"
      },
      "leads_added": {
        "type": "integer",
        "description": "Total new leads added this week"
      },
      "messages_sent": {
        "type": "integer",
        "description": "Total messages sent (approved and actually sent)"
      },
      "replies_received": {
        "type": "integer"
      },
      "reply_rate_pct": {
        "type": "string",
        "description": "replies_received / messages_sent × 100",
        "example": "33%"
      },
      "positive_replies": {
        "type": "integer",
        "description": "Replies classified as Positive Interest, Wants Demo, Wants Call, Wants Pricing, or Wants Signup"
      },
      "positive_reply_rate_pct": {
        "type": "string",
        "description": "positive_replies / messages_sent × 100"
      },
      "calls_booked": {
        "type": "integer"
      },
      "call_booking_rate_pct": {
        "type": "string",
        "description": "calls_booked / positive_replies × 100"
      },
      "signups": {
        "type": "integer"
      },
      "signup_rate_pct": {
        "type": "string",
        "description": "signups / total_leads_in_outreach × 100"
      },
      "top_lead_type": {
        "type": "string",
        "description": "Lead type with highest reply or conversion rate this week"
      },
      "top_channel": {
        "type": "string",
        "description": "Channel with highest reply rate"
      },
      "top_angle": {
        "type": "string",
        "description": "Message angle that generated the most positive responses"
      },
      "top_objection_1": { "type": "string" },
      "top_objection_2": { "type": "string" },
      "top_objection_3": { "type": "string" },
      "recommendation_1": { "type": "string" },
      "recommendation_2": { "type": "string" },
      "recommendation_3": { "type": "string" },
      "pipeline_outreach_sent": { "type": "integer" },
      "pipeline_follow_up_active": { "type": "integer" },
      "pipeline_call_requested": { "type": "integer" },
      "pipeline_demo_requested": { "type": "integer" },
      "pipeline_pricing_asked": { "type": "integer" },
      "pipeline_signup_ready": { "type": "integer" },
      "pipeline_closed": { "type": "integer" },
      "notes": { "type": "string" }
    }
  },

  "signups_tab": {
    "description": "Tracks every lead who successfully signs up for Autom8.",
    "google_sheet_tab": "Signups",
    "column_order": [
      "signup_id", "date", "lead_id", "name", "company",
      "email", "linkedin_url", "instagram_url",
      "plan_selected", "acquisition_channel",
      "first_outreach_date", "days_to_signup",
      "touch_count_at_signup", "conversion_path",
      "notes"
    ],
    "properties": {
      "signup_id": {
        "type": "string",
        "description": "Unique signup ID. Format: SIGNUP-001"
      },
      "date": {
        "type": "string",
        "format": "date",
        "description": "Date of signup"
      },
      "lead_id": {
        "type": "string",
        "description": "Matching lead_id"
      },
      "name": { "type": "string" },
      "company": { "type": "string" },
      "email": { "type": "string" },
      "linkedin_url": { "type": "string" },
      "instagram_url": { "type": "string" },
      "plan_selected": {
        "type": "string",
        "description": "Which Autom8 plan they signed up for"
      },
      "acquisition_channel": {
        "type": "string",
        "enum": ["LinkedIn", "Email", "Instagram DM", "Inbound", "Referral", "Other"],
        "description": "Channel that started the acquisition sequence"
      },
      "first_outreach_date": {
        "type": "string",
        "format": "date"
      },
      "days_to_signup": {
        "type": "integer",
        "description": "Days between first outreach and signup"
      },
      "touch_count_at_signup": {
        "type": "integer",
        "description": "How many touches it took to get to signup"
      },
      "conversion_path": {
        "type": "string",
        "description": "Key milestones in the conversion: e.g., Cold outreach → Demo request → Call → Signup",
        "example": "LinkedIn cold → Positive reply → Demo link sent → Signup"
      },
      "notes": { "type": "string" }
    }
  },

  "google_sheets_tab_summary": {
    "tabs": [
      {
        "tab_name": "Leads",
        "description": "Master lead database. One row per lead.",
        "managed_by": "Lead Researcher Agent",
        "key_columns": ["lead_id", "name", "company", "lead_temperature", "status"]
      },
      {
        "tab_name": "Connection_Follow_Queue",
        "description": "Tracks follow-up timing and cadence for all active leads.",
        "managed_by": "Follow-Up Manager Agent",
        "key_columns": ["lead_id", "touch_count", "next_touch_date", "should_continue"]
      },
      {
        "tab_name": "Message_Drafts",
        "description": "All outreach drafts awaiting human review. Nothing sends without approval.",
        "managed_by": "Outreach Strategist Agent",
        "key_columns": ["draft_id", "lead_id", "initial_message", "status"]
      },
      {
        "tab_name": "Conversations",
        "description": "Every reply received, classified, and responded to.",
        "managed_by": "Conversation Handler Agent",
        "key_columns": ["conversation_id", "reply_classification", "draft_reply", "status_update"]
      },
      {
        "tab_name": "Call_Requests",
        "description": "Tracks every lead who requested a strategy call.",
        "managed_by": "Notification Agent + Conversation Handler",
        "key_columns": ["call_request_id", "name", "booking_link_sent", "call_booked", "call_outcome"]
      },
      {
        "tab_name": "Signups",
        "description": "Tracks every confirmed signup from outreach.",
        "managed_by": "Manual entry + Notification Agent",
        "key_columns": ["signup_id", "name", "plan_selected", "acquisition_channel", "days_to_signup"]
      },
      {
        "tab_name": "Analytics",
        "description": "Weekly performance reports from the Sales Analyzer Agent.",
        "managed_by": "Sales Analyzer Agent",
        "key_columns": ["report_id", "reply_rate_pct", "calls_booked", "signups", "recommendations"]
      }
    ]
  },

  "sample_analytics_row": {
    "report_id": "REPORT-001",
    "report_date": "2026-05-14",
    "week_start": "2026-05-07",
    "week_end": "2026-05-13",
    "leads_added": 24,
    "messages_sent": 18,
    "replies_received": 6,
    "reply_rate_pct": "33%",
    "positive_replies": 4,
    "positive_reply_rate_pct": "22%",
    "calls_booked": 1,
    "call_booking_rate_pct": "25%",
    "signups": 0,
    "signup_rate_pct": "0%",
    "top_lead_type": "SaaS Founder",
    "top_channel": "LinkedIn",
    "top_angle": "Missed Comment / Lead Gap",
    "top_objection_1": "Already have a tool",
    "top_objection_2": "Budget timing",
    "top_objection_3": "Worried about feeling fake",
    "recommendation_1": "SaaS founders replying at 3x rate — increase their proportion next week",
    "recommendation_2": "Missed comment angle works best — test it in initial message for hot leads",
    "recommendation_3": "Email generating zero replies — pause and focus on LinkedIn DM",
    "pipeline_outreach_sent": 12,
    "pipeline_follow_up_active": 6,
    "pipeline_call_requested": 1,
    "pipeline_demo_requested": 2,
    "pipeline_pricing_asked": 1,
    "pipeline_signup_ready": 0,
    "pipeline_closed": 3,
    "notes": "Week 1 baseline. Metrics will normalize as more outreach data accumulates."
  },

  "sample_signup_row": {
    "signup_id": "SIGNUP-001",
    "date": "2026-05-21",
    "lead_id": "LEAD-001",
    "name": "Jordan Mills",
    "company": "Stackr Studio",
    "email": "jordan@stackrstudio.com",
    "linkedin_url": "https://linkedin.com/in/jordanmills",
    "instagram_url": "https://instagram.com/jordanmills.builds",
    "plan_selected": "Growth Plan",
    "acquisition_channel": "LinkedIn",
    "first_outreach_date": "2026-05-14",
    "days_to_signup": 7,
    "touch_count_at_signup": 3,
    "conversion_path": "LinkedIn cold outreach → Positive reply → Strategy call → Signup",
    "notes": "Fast conversion — SaaS founder with clear use case. Strategy call sealed it."
  }
}
