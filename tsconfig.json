{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "agents/**/*",
    "config/**/*",
    "schemas/**/*",
    "services/**/*",
    "tools/**/*",
    "utils/**/*",
    "workflows/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
